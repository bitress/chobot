# ==========================================
# APP CONFIGURATION
# ==========================================
IS_PRODUCTION=
WORKBOOK_NAME=

# ==========================================
# DISCORD CONFIGURATION
# ==========================================
DISCORD_TOKEN=..
GUILD_ID=
SUB_CATEGORY_ID=
FREE_CATEGORY_ID=
ISLAND_ACCESS_ROLE=

# --- Channel IDs ---
CHANNEL_ID=
FLIGHT_LISTEN_CHANNEL_ID=
FREE_ISLAND_FLIGHT_LISTEN_CHANNEL_ID=
FLIGHT_LOG_CHANNEL_ID=
IGNORE_CHANNEL_ID=
SUB_MOD_CHANNEL_ID=
FIND_BOT_CHANNEL_ID=
# Channel ID to learn from (messages passively ingested as AI context)
AI_LEARN_CHANNEL_ID=907642922906845264
# Channel where the live Free Island Dodo board is kept updated
FREE_DODO_BOARD_CHANNEL_ID=1500493205672825056
# Comma-separated channels where Berichan/OrderBot posts Dodo code messages.
# ChoBot watches these locally and updates the dashboard island Dodo/status.
ORDERBOT_CHANNEL_IDS=
# Optional comma-separated Discord bot user IDs allowed to update Dodo codes.
# Leave blank to accept any author in ORDERBOT_CHANNEL_IDS.
ORDERBOT_AUTHOR_IDS=
# Mark captured Dodo codes stale after this many minutes in future cleanup jobs.
DODO_STALE_MINUTES=120

# ==========================================
# TWITCH CONFIGURATION
# ==========================================
TWITCH_TOKEN=
TWITCH_CHANNEL=

# ==========================================
# PATREON CONFIGURATION
# ==========================================
PATREON_TOKEN=
PATREON_CAMPAIGN_ID=

# ==========================================
# LOCAL FILE PATHS
# ==========================================
# Path for Discord Orders
VILLAGERS_DIR=

# Path for Twitch Orders
TWITCH_VILLAGERS_DIR=

# ==========================================
# NOOKIPEDIA (optional)
# ==========================================
NOOKIPEDIA_KEY=

# ==========================================
# AI PROVIDERS (optional)
# ==========================================
# Choose: auto | openai | gemini
# auto = try OPENAI_API_KEY first, then GEMINI_API_KEY.
AI_PROVIDER=openai

# OpenAI
# Get your key at https://platform.openai.com/
OPENAI_API_KEY=
# Optional custom endpoint/base URL (leave blank for default OpenAI endpoint).
# Default endpoint is https://api.openai.com/v1
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Gemini (free tier)
# Get your free key at https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ==========================================
# ISLAND BOT ROLE (SYSBOT)
# ==========================================
# Role shared by all 18 island SysBots (named "Chobot <island name>").
# Used by !islandstatus to locate each island's bot by name.
ISLAND_BOT_ROLE_ID=788749941949464577

# ==========================================
# WEB DASHBOARD (mod-only)
# ==========================================
# Secret key mods enter to log in to /dashboard/
DASHBOARD_SECRET=change-me-to-a-strong-secret

# Flask session signing key (auto-derived from DASHBOARD_SECRET if not set)
FLASK_SECRET_KEY=

# ==========================================
# DISCORD OAUTH2 (dashboard login)
# ==========================================
# Enables "Log in with Discord" on the dashboard login page.
# 1. Go to https://discord.com/developers/applications and create an application.
# 2. Under OAuth2 → Redirects, add:
#    https://your-domain/dashboard/oauth2/callback
#    (or http://localhost:5000/dashboard/oauth2/callback for local dev)
# 3. Copy the Client ID and Client Secret below.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Senior Mod role ID granted dashboard access via Discord OAuth.
# Any server member with the Discord Administrator permission is also granted
# access automatically.  Must be set — role IDs are unique per Discord server.
ADMIN_ROLE_ID=

# Mod roles — members with these roles can access ALL islands on the website
# regardless of their subscription tier.
SENIOR_MOD_ROLE_ID=
BABY_MOD_ROLE_ID=

# Subscription tier role IDs — used to gate dodo code reveals on the website.
# Members need at least one matching role for the island they're trying to access.
ROLE_CHOSOUP=
ROLE_Y_CHOSOUP=
ROLE_CHOTATO_CLUB=
ROLE_Y_CHOTATO_CLUB=
ROLE_CHOCOLATE=
ROLE_CHOFRIES=
ROLE_Y_CHOCOLATE=

# Discord webhook URL for logging dodo code reveals on the public website.
# Create a webhook in your Discord server and paste the URL here.
DODO_LOG_WEBHOOK_URL=

# ==========================================
# CLOUDFLARE R2 — Island map uploads
# ==========================================
# Your Cloudflare account ID (find it in the R2 dashboard URL)
R2_ACCOUNT_ID=
# R2 API token credentials (create an R2 API token with Object Read & Write)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# The R2 bucket name to store uploaded island maps
R2_BUCKET_NAME=chobot-maps
# Public base URL for reading uploaded files.
# Use your R2 public bucket URL, R2.dev sub-domain, or custom domain.
# Example: https://pub-xxxxxxxxxxxx.r2.dev
R2_PUBLIC_URL=

# ==========================================
# DATABASE
# ==========================================
# sqlite is the default and uses chobot.db in the project root.
# Set DB_BACKEND=mysql to run the Flask API and bots from MySQL/MariaDB.
DB_BACKEND=sqlite
SQLITE_DB_PATH=
DATABASE_URL=

MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=chobot

# Backward-compatible aliases; MYSQL_* takes priority when both are set.
MARIADB_HOST=
MARIADB_PORT=3306
MARIADB_USER=
MARIADB_PASSWORD=
MARIADB_DATABASE=chobot
# true = TRUNCATE target tables before import; false = append rows
MARIADB_TRUNCATE_BEFORE_IMPORT=true
