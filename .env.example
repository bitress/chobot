# ==========================================
# APP
# ==========================================
IS_PRODUCTION=false
WORKBOOK_NAME=ChoPaeng_Database
BACKUP_DIR=backups
BACKUP_INTERVAL_HOURS=24
HEALTH_CACHE_MAX_AGE_SECONDS=7200
SERVICE_HEARTBEAT_INTERVAL_SECONDS=60

# Optional TLS CA bundle override. Leave blank to let the app use certifi.
SSL_CERT_FILE=

# ==========================================
# DISCORD
# ==========================================
DISCORD_TOKEN=
GUILD_ID=

# Main member island category and optional free island category.
SUB_CATEGORY_ID=
FREE_CATEGORY_ID=

# Role used as the fallback member/subscriber access role.
# Per-island website access is normally resolved from Discord channel overwrites.
ISLAND_ACCESS_ROLE=

# Moderator/admin roles.
ADMIN_ROLE_ID=
SENIOR_MOD_ROLE_ID=
BABY_MOD_ROLE_ID=

# Channels.
CHANNEL_ID=
FLIGHT_LISTEN_CHANNEL_ID=
FREE_ISLAND_FLIGHT_LISTEN_CHANNEL_ID=
FLIGHT_LOG_CHANNEL_ID=
IGNORE_CHANNEL_ID=
SUB_MOD_CHANNEL_ID=
XLOG_VERBOSE_CHANNEL_ID=
FIND_BOT_CHANNEL_ID=
AI_LEARN_CHANNEL_ID=
FREE_DODO_BOARD_CHANNEL_ID=
WEBSITE_LOGIN_LOG_CHANNEL_ID=

# SysBot role used for island bot status checks.
ISLAND_BOT_ROLE_ID=

# ==========================================
# TWITCH
# ==========================================
TWITCH_TOKEN=
TWITCH_CHANNEL=

# ==========================================
# DATA SOURCES
# ==========================================
PATREON_TOKEN=
PATREON_CAMPAIGN_ID=
NOOKIPEDIA_KEY=

# Local island data directories.
VILLAGERS_DIR=
TWITCH_VILLAGERS_DIR=
ORDER_BOT_DIR=
ORDER_BOT_ISLAND=Sinta
ORDER_BOT_CHANNEL_ID=
ORDER_BOT_DISCORD_ID=
ORDER_BOT_TWITCH_CHANNEL=

# ==========================================
# AI PROVIDERS
# ==========================================
# Choose: auto | openai | gemini
AI_PROVIDER=auto

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ==========================================
# WEB / DASHBOARD
# ==========================================
DASHBOARD_SECRET=
FLASK_SECRET_KEY=

# Keep server-rendered dashboard pages enabled. Set false once a frontend app
# owns the dashboard UI and uses /dashboard/api/*.
DASHBOARD_LEGACY_JINJA=true
DASHBOARD_FRONTEND_URL=

# Comma-separated browser origins allowed by Flask-CORS.
FRONTEND_ORIGINS=https://www.chopaeng.com,https://chopaeng.com,http://localhost:5173,http://localhost:3000

# Public API base URL used by Discord commands that link to the website.
API_BASE_URL=https://console.chopaeng.com

# Discord OAuth2 dashboard login.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Discord webhook URL for logging public website dodo-code reveals.
DODO_LOG_WEBHOOK_URL=

# ==========================================
# CLOUDFLARE R2 MAP UPLOADS
# ==========================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=chobot-maps
R2_PUBLIC_URL=

# ==========================================
# DATABASE
# ==========================================
# sqlite is the default and uses chobot.db in the project root.
# Use mysql or mariadb after running the SQLite -> MariaDB migration.
DB_BACKEND=sqlite
SQLITE_DB_PATH=
DATABASE_URL=

MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=chobot

# Backward-compatible aliases. MYSQL_* takes priority when both are set.
MARIADB_HOST=
MARIADB_PORT=3306
MARIADB_USER=
MARIADB_PASSWORD=
MARIADB_DATABASE=chobot
MARIADB_TRUNCATE_BEFORE_IMPORT=true
